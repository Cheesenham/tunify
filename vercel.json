{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/maker",
      "destination": "/public/maker.html"
    },
    {
      "source": "/player",
      "destination": "/public/player.html"
    },
    {
      "source": "/",
      "destination": "/public/index.html"
    }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python"
    }
  }
}